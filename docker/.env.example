# Colony environment variables
# Copy this file to .env (in your colony directory) and fill in the values.
# Never commit .env to version control.

# ── Agent credentials (at least one required) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...   # for claude-cli ants (default engine)
GEMINI_API_KEY=AIza...         # for gemini-cli ants

# ── Integrations (all optional) ────────────────────────────────────────────
DISCORD_TOKEN=                 # full Discord bot — two-way control
DISCORD_WEBHOOK_URL=           # OR: webhook-only send-only notifications

# ── Dashboard auth (optional) ──────────────────────────────────────────────
# Set a secret string to require an API key on the web dashboard and HTTP API.
# Leave blank (or remove) to allow unauthenticated access (fine for localhost).
COLONY_API_KEY=
